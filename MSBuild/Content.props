<Project>
  <!--
  Content specific properties
  Import *before* Robust.Properties.targets
  -->

  <PropertyGroup>
    <LangVersion Condition="'$(LangVersion)' == ''">14</LangVersion>
    <IsPackable Condition="'$(IsPackable)' == ''">false</IsPackable>
    <Nullable Condition="'$(Nullable)' == ''">enable</Nullable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors> <!-- ADT: We have a lot of warnings, and we don't want to fail the build because of them. -->
    <WarningsNotAsErrors>CS0618,CS0672,CS0612,CS1062,CS1064,NU1900,NU1901,NU1902,NU1903,NU1904</WarningsNotAsErrors>
  </PropertyGroup>
</Project>
