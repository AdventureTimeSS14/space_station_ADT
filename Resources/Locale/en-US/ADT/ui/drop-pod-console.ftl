## Drop Pod Console UI strings

drop-pod-console-title = Drop Pod Deployment Console

drop-pod-console-compass-title = SELECT TARGET SECTOR

drop-pod-console-sector-none = No sector selected.
drop-pod-console-sector-selected = Target sector: { $dir }

drop-pod-console-deploy-button = DEPLOY DROP POD

drop-pod-console-status-ready = Status: Ready — select a sector and deploy.
drop-pod-console-status-not-ready = Status: System cooling down. Please wait.
drop-pod-console-status-launched = Status: Drop pod already deployed.

drop-pod-console-notice = WARNING: Operatives not seated during landing will sustain injuries.

## Direction names used in both UI and announcements

drop-pod-direction-north = north
drop-pod-direction-east = east
drop-pod-direction-south = south
drop-pod-direction-west = west

## Announcement sent when a launch is initiated
## {$direction} – cardinal sector (north/east/south/west)
## {$seconds}   – lead time in whole seconds
drop-pod-console-launch-announcement = ALERT: A Syndicate drop pod has been detected targeting the {$direction} sector of the station. Brace for impact in {$seconds} seconds!

drop-pod-console-sender = Central Command