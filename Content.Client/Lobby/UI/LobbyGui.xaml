<lobbyUi:LobbyGui
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maths="clr-namespace:Robust.Shared.Maths;assembly=Robust.Shared.Maths"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:vote="clr-namespace:Content.Client.Voting.UI"
    xmlns:style="clr-namespace:Content.Client.Stylesheets"
    xmlns:lobbyUi="clr-namespace:Content.Client.Lobby.UI"
    xmlns:info="clr-namespace:Content.Client.Info"
    xmlns:widgets="clr-namespace:Content.Client.UserInterface.Systems.Chat.Widgets"
    xmlns:menu="clr-namespace:Content.Client.MainMenu.UI"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client">

    <!-- Параллакс фон -->
    <menu:MainMenuParallaxControl_Duty Name="ParallaxBackground" />

    <!-- Виньетка -->
    <lobbyUi:LobbyVignette_Duty Name="VignetteDuty" />

    <!-- Основной контейнер -->
    <BoxContainer Name="MainContainer" Orientation="Horizontal" SeparationOverride="0">

        <!-- ЛЕВАЯ ЧАСТЬ -->
        <BoxContainer Name="LeftSide" Orientation="Vertical" MinWidth="280" MaxWidth="280" VerticalExpand="True">

            <Control Name="DefaultState" VerticalExpand="True">

                <!-- Таймер раунда -->
                <Label Name="StartTime" Access="Public" Align="Left"
                       FontColorOverride="{x:Static maths:Color.LightGray}"
                       VerticalAlignment="Top" HorizontalAlignment="Left"
                       Margin="20 15 0 0" />

                <!-- Голосования — под таймером -->
                <BoxContainer Orientation="Vertical" SeparationOverride="4"
                              Name="VoteContainer" Access="Public"
                              HorizontalAlignment="Left" VerticalAlignment="Top"
                              Margin="20 40 0 0" />

                <!-- Блок кнопок по центру -->
                <BoxContainer Name="ButtonsContainer" Orientation="Vertical"
                              SeparationOverride="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Margin="20 0 0 0">

                    <!-- Логотип LocalDuty -->
                    <lobbyUi:LobbyLogoDuty Name="LogoDuty" Margin="0 0 0 14" />

                    <!-- Кнопки с анимацией -->
                    <lobbyUi:LobbyAnimatedButton Name="ObserveButton" Access="Public"
                            Text="{Loc 'ui-lobby-observe-button'}" />

                    <lobbyUi:LobbyAnimatedButton Name="ReadyButton" Access="Public"
                            ToggleMode="True"
                            Text="{Loc 'ui-lobby-ready-up-button'}" />

                    <lobbyUi:LobbyAnimatedButton Name="CharacterSetupButton_Duty" Access="Public"
                            Text="Персонализация" />

                    <lobbyUi:LobbyAnimatedButton Name="OptionsButton" Access="Public"
                            Text="{Loc 'ui-lobby-options-button'}" />

                    <lobbyUi:LobbyAnimatedButton Name="AHelpButton" Access="Public"
                            Text="{Loc 'ui-lobby-ahelp-button'}" />

                    <!-- Визуальный разделитель -->
                    <Control MinHeight="10" />

                    <lobbyUi:LobbyAnimatedButton Name="GuideButton" Access="Public"
                            Text="Руководство" />

                    <lobbyUi:LobbyAnimatedButton Name="DiscordButton" Access="Public"
                            Text="Дискорд" />

                    <lobbyUi:LobbyAnimatedButton Name="LeaveButton" Access="Public"
                            Text="{Loc 'ui-lobby-leave-button'}" />

                </BoxContainer>

                <!-- Скрытые элементы для логики -->
                <Button Name="ManifestButton" Access="Public" Visible="False"
                        Text="{Loc 'ui-lobby-manifest-button'}" />
                <RichTextLabel Name="PlaytimeComment" Visible="False" Access="Public" />
                <RichTextLabel Name="LobbyMessageLabel" Access="Public" Visible="False" />

            </Control>

        </BoxContainer>

        <!-- ЦЕНТР — пустое пространство -->
        <Control HorizontalExpand="True" />

        <!-- ПРАВАЯ ПАНЕЛЬ -->
        <PanelContainer Name="RightSide" Access="Public" StyleClasses="BorderedWindowPanel"
                        VerticalExpand="True">
            <BoxContainer Orientation="Vertical" HorizontalExpand="True">
                <BoxContainer Orientation="Horizontal" MinSize="0 40" Name="HeaderContainer" Access="Public"
                              SeparationOverride="4">
                    <Label Name="ServerName" Access="Public" StyleClasses="LabelHeadingBigger" VAlign="Center"
                           HorizontalExpand="True" HorizontalAlignment="Center" />
                </BoxContainer>
                <controls:HLine Color="{x:Static style:StyleNano.NanoGold}" Thickness="2" />
                <controls:HSpacer Spacing="4" />
                <vote:VoteCallMenuButton Name="CallVoteButton" Visible="False" />
                <controls:NanoHeading Text="{Loc 'ui-lobby-server-info-block'}" />
                <info:ServerInfo Name="ServerInfo" Access="Public" MinSize="0 30" VerticalExpand="false"
                                 Margin="3 3 3 3" MaxWidth="400" HorizontalAlignment="Left" />
                <Label Name="StationTime" Access="Public" FontColorOverride="{x:Static maths:Color.LightGray}"
                       Margin="3 3 3 3" HorizontalAlignment="Left" />
                <controls:HSpacer Spacing="5" />
                <lobbyUi:LobbyCharacterPreviewPanel Name="CharacterPreview" Access="Public" />
                <controls:HSpacer Spacing="5" />
                <BoxContainer MinHeight="10" />
                <Label Name="Balance" Access="Public" Visible="False" StyleClasses="LabelHeadingBigger"
                       VAlign="Center" HorizontalExpand="True" HorizontalAlignment="Center" />
                <controls:HLine Color="{x:Static style:StyleNano.NanoGold}" Thickness="2" Access="Public" />
                <controls:HSpacer Spacing="10" />
                <widgets:ChatBox Name="Chat" Access="Public" VerticalExpand="True" Margin="3 3 3 3" MinHeight="50" />
            </BoxContainer>
            <TextureButton Name="CollapseButton"
                           TexturePath="filled_right_arrow.svg.192dpi"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0 2 2 0" ModulateSelfOverride="#DEDEDE" Scale="0.5 0.5"/>
        </PanelContainer>

    </BoxContainer>

    <!-- "Гойда!" снизу по центру -->
    <Label Name="GoydaLabel"
           Text="Гойда!"
           FontColorOverride="{x:Static maths:Color.White}"
           HorizontalAlignment="Center"
           VerticalAlignment="Bottom"
           LayoutContainer.AnchorLeft="0"
           LayoutContainer.AnchorRight="1"
           LayoutContainer.AnchorTop="1"
           LayoutContainer.AnchorBottom="1"
           LayoutContainer.GrowVertical="Begin"
           Margin="0 0 0 12" />

    <!-- Скрытые — нужны для совместимости с кодом -->
    <PanelContainer StyleClasses="AngleRect" Visible="False">
        <RichTextLabel Name="LobbySong" Access="Public" />
    </PanelContainer>
    <PanelContainer StyleClasses="AngleRect" Visible="False">
        <RichTextLabel Name="LobbyBackground" Access="Public" />
    </PanelContainer>
    <info:DevInfoBanner Name="DevInfoBanner" Visible="False" />

    <!-- CharacterSetupState — полноэкранный слой -->
    <Control Access="Public" Visible="False" Name="CharacterSetupState" />

    <!-- Expand panel -->
    <PanelContainer Name="ExpandPanel" StyleClasses="BorderedWindowPanel"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0 2 2 0" Visible="False">
        <TextureButton Name="ExpandButton"
                       TexturePath="filled_left_arrow.svg.192dpi"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       ModulateSelfOverride="#DEDEDE" Scale="0.5 0.5"/>
    </PanelContainer>

</lobbyUi:LobbyGui>
